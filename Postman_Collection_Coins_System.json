          ]
        },
        {
          "name": "Get All Submissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["submissions"]
            }
          },
