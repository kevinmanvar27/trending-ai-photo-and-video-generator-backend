{
  "info": {
    "name": "Coins System - Image Templates API",
    "description": "Test collection for the coins-based image template system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearer_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "bearer_token",
      "value": "YOUR_TOKEN_HERE",
      "type": "string"
    },
    {
      "key": "template_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Templates",
      "item": [
        {
          "name": "Get All Templates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/templates",
              "host": ["{{base_url}}"],
              "path": ["templates"]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Template",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/templates/{{template_id}}",
              "host": ["{{base_url}}"],
              "path": ["templates", "{{template_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get Popular Templates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/templates/popular",
              "host": ["{{base_url}}"],
              "path": ["templates", "popular"]
            }
          },
          "response": []
        },
        {
          "name": "Create Template (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Test Template with Coins",
                  "type": "text"
                },
                {
                  "key": "prompt",
                  "value": "A beautiful landscape with mountains",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "landscape",
                  "type": "text"
                },
                {
                  "key": "coins_required",
                  "value": "10",
                  "type": "text",
                  "description": "Number of coins required to use this template"
                },
                {
                  "key": "is_active",
                  "value": "1",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/templates",
              "host": ["{{base_url}}"],
              "path": ["templates"]
            }
          },
          "response": []
        },
        {
          "name": "Update Template",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Template Name\",\n  \"prompt\": \"Updated prompt text\",\n  \"category\": \"portrait\",\n  \"coins_required\": 15,\n  \"is_active\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/templates/{{template_id}}",
              "host": ["{{base_url}}"],
              "path": ["templates", "{{template_id}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
