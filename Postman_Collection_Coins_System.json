                  "description": "ID of the template to use"
                },
                {
                  "key": "user_image",
                  "type": "file",
                  "src": [],
                  "description": "User's image file (JPG, PNG)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["submissions"]
